{
  "name": "smart-academy-congo",
  "version": "1.0.0",
  "private": true,
  "description": "Evo-smartUni — site web + proxy API (Render Web Service Node)",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node -e \"require('fs').accessSync('server.js'); console.log('Node frontend ready')\"",
    "start": "node server.js",
    "check:health": "node scripts/check-health.js",
    "check:node-deploy": "node scripts/check-node-deploy.js",
    "check:frontend": "node scripts/check-health.js http://127.0.0.1:10000",
    "validate": "node scripts/validate-frontend.js",
    "bootstrap:accounts": "node scripts/bootstrap-institutional-accounts.mjs"
  },
  "dependencies": {
    "express": "^4.21.2",
    "http-proxy-middleware": "^3.0.3"
  }
}
